# ─── Supabase (optional — ohne Werte laeuft Demo-Mode mit Fallback-Daten) ───
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─── Resend (E-Mail, optional — ohne Werte werden E-Mails stillschweigend ausgelassen) ───
RESEND_API_KEY=
FROM_EMAIL=noreply@ihre-domain.ch
RECIPIENT_EMAIL=chef@ihre-domain.ch

# ─── Admin-Login (optional — ohne Hash ist /admin offen, Demo-Modus) ───
# Generate: node -e "console.log(require('crypto').createHash('sha256').update('DEIN_PASSWORT').digest('hex'))"
ADMIN_PASSWORD_HASH=

# ─── Google Reviews (optional) ───
GOOGLE_PLACES_API_KEY=
GOOGLE_PLACE_ID=

# ─── Site (fuer sitemap.xml, robots.txt, LocalBusiness-Schema) ───
SITE_URL=https://ihre-domain.ch
NEXT_PUBLIC_SITE_URL=https://ihre-domain.ch

# ─── Branche: elektriker | sanitaer | maler | schreiner ───
NEXT_PUBLIC_BRANCHE=maler
